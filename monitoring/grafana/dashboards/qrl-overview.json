{
  "dashboard": {
    "title": "QRL Network Overview",
    "uid": "qrl-overview",
    "timezone": "browser",
    "refresh": "10s",
    "panels": [
      {
        "title": "Head Slot",
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
        "targets": [
          {
            "expr": "max(beacon_head_slot)",
            "legendFormat": "Head Slot"
          }
        ]
      },
      {
        "title": "Finalized Epoch",
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
        "targets": [
          {
            "expr": "max(beacon_finalized_epoch)",
            "legendFormat": "Finalized Epoch"
          }
        ]
      },
      {
        "title": "Finality Delay (epochs)",
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
        "targets": [
          {
            "expr": "max(beacon_head_slot) / 128 - max(beacon_finalized_epoch)",
            "legendFormat": "Delay"
          }
        ]
      },
      {
        "title": "Beacon Peer Count",
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
        "targets": [
          {
            "expr": "avg(p2p_peer_count{job=\"beacon\"})",
            "legendFormat": "Avg Peers"
          }
        ]
      },
      {
        "title": "Head Slot per Beacon Node",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
        "targets": [
          {
            "expr": "beacon_head_slot",
            "legendFormat": "{{ instance }}"
          }
        ]
      },
      {
        "title": "P2P Peer Count per Node",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
        "targets": [
          {
            "expr": "p2p_peer_count{state=\"Connected\",job=\"beacon\"}",
            "legendFormat": "{{ instance }}"
          }
        ]
      },
      {
        "title": "Aggregated Attestations",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
        "targets": [
          {
            "expr": "rate(beacon_aggregated_attestation_count[5m])",
            "legendFormat": "{{ instance }}"
          }
        ]
      },
      {
        "title": "Execution Peer Count",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
        "targets": [
          {
            "expr": "p2p_peers{job=\"execution\"}",
            "legendFormat": "{{ instance }}"
          }
        ]
      },
      {
        "title": "Execution TX Pool Size",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
        "targets": [
          {
            "expr": "txpool_pending{job=\"execution\"}",
            "legendFormat": "pending {{ instance }}"
          },
          {
            "expr": "txpool_queued{job=\"execution\"}",
            "legendFormat": "queued {{ instance }}"
          }
        ]
      },
      {
        "title": "Block Gas Used",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
        "targets": [
          {
            "expr": "chain_head_gas_used{job=\"execution\"}",
            "legendFormat": "{{ instance }}"
          }
        ]
      }
    ],
    "time": { "from": "now-1h", "to": "now" }
  }
}